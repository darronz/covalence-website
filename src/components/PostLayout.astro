---
import '../styles/posts.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const author = post.data.author ?? 'Darron Schall';

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const pubDateFormatted = dateFormatter.format(post.data.pub_date);
const updatedFormatted = post.data.updated_date
  ? dateFormatter.format(post.data.updated_date)
  : null;
---

<main class="post-page">
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-meta">
        <time datetime={post.data.pub_date.toISOString()}>{pubDateFormatted}</time>
        <span class="post-meta-sep"> · </span>
        <span>{author}</span>
        {updatedFormatted && (
          <>
            <span class="post-meta-sep"> · </span>
            <span>Updated {updatedFormatted}</span>
          </>
        )}
      </p>
    </header>
    <hr class="post-divider" />
    <div class="prose">
      <slot />
    </div>
  </article>
</main>

<style>
  .post-page {
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-2xl);
  }

  .post {
    max-width: 44rem;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .post-header {
    margin-bottom: var(--space-lg);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 var(--space-md);
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .post-meta-sep {
    margin: 0 0.25rem;
  }

  .post-divider {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 0 0 var(--space-lg);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.875rem;
    }

    .post {
      padding: 0 var(--space-md);
    }
  }
</style>
