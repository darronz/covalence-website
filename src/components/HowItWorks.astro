<section id="how-it-works" class="section">
  <div class="container">
    <h2 class="section-title">Two copy-pastes. That's it.</h2>
    <div class="steps">
      <div class="step">
        <div class="step-number">1</div>
        <h3>Install</h3>
        <p>Download the app. It lives in your menu bar.</p>
      </div>
      <div class="step">
        <div class="step-number">2</div>
        <h3>Connect</h3>
        <p>Paste the MCP config into your AI client.</p>
        <div class="code-block">
          <div class="code-header">
            <span>Claude Desktop — config.json</span>
          </div>
          <pre><code>{`{
  "mcpServers": {
    "covalence": {
      "command": "/Applications/Covalence.app/Contents/MacOS/cov-mcp"
    }
  }
}`}</code></pre>
        </div>
      </div>
      <div class="step">
        <div class="step-number">3</div>
        <h3>Done</h3>
        <p>Your AI remembers. No accounts, no API keys, no cloud.</p>
      </div>
    </div>
  </div>
</section>

