<script is:inline>
  (function () {
    var toggle = document.querySelector('[data-nav-toggle]');
    var drawer = document.getElementById('mobile-menu');
    if (!toggle || !drawer) return;

    var closeTimer;

    function openMenu() {
      clearTimeout(closeTimer);
      drawer.hidden = false;
      // One frame gap so the transition actually fires.
      requestAnimationFrame(function () {
        drawer.classList.add('nav-drawer-open');
      });
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      toggle.classList.add('is-open');
      document.addEventListener('keydown', onKeydown);
      document.addEventListener('click', onOutsideClick, true);
    }

    function closeMenu() {
      drawer.classList.remove('nav-drawer-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      toggle.classList.remove('is-open');
      document.removeEventListener('keydown', onKeydown);
      document.removeEventListener('click', onOutsideClick, true);
      // Match CSS transition duration (180ms) before hiding from AT / layout.
      closeTimer = setTimeout(function () {
        if (toggle.getAttribute('aria-expanded') === 'false') {
          drawer.hidden = true;
        }
      }, 200);
    }

    function onKeydown(e) {
      if (e.key === 'Escape') closeMenu();
    }

    function onOutsideClick(e) {
      if (!drawer.contains(e.target) && !toggle.contains(e.target)) {
        closeMenu();
      }
    }

    toggle.addEventListener('click', function () {
      if (toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      } else {
        openMenu();
      }
    });

    drawer.addEventListener('click', function (e) {
      if (e.target && e.target.tagName === 'A') closeMenu();
    });

    // Close if the viewport grows back to desktop so we don't leave a
    // stranded drawer visible next to the now-visible desktop links.
    window.addEventListener('resize', function () {
      if (window.innerWidth >= 900 && toggle.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  })();
</script>

