---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import Architecture from '../components/Architecture.astro';
import Footer from '../components/Footer.astro';
import PostList from '../components/PostList.astro';

const showLatestWriting = true;
const latestPosts = showLatestWriting
  ? (await getCollection('posts'))
      .sort((a, b) => b.data.pub_date.valueOf() - a.data.pub_date.valueOf())
      .slice(0, 2)
  : [];
---

<Base
  title="Covalence – Cross-client memory for Claude, Cursor, and MCP (macOS)"
  description="A native macOS app that gives any AI client persistent, semantic, long-term memory — locally, privately, and without configuration."
>
  <Nav />
  <main id="main-content">
    <Hero />
    <HowItWorks />
    <Features />
    <Architecture />

    {latestPosts.length > 0 && (
      <section class="latest-writing">
        <div class="container">
          <header class="latest-writing-header">
            <p class="latest-writing-eyebrow">Writing</p>
            <h2 class="latest-writing-heading">Latest writing</h2>
          </header>
          <PostList posts={latestPosts} limit={2} />
          <p class="latest-writing-more">
            <a href="/posts/">Read all posts →</a>
          </p>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Base>

<style>
  .latest-writing {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }

  .latest-writing-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .latest-writing-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  .latest-writing-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .latest-writing-more {
    text-align: center;
    margin-top: var(--space-lg);
    font-size: 0.9375rem;
  }

  .latest-writing-more a {
    color: var(--accent-subtle);
  }

  .latest-writing-more a:hover {
    color: var(--accent-subtle-hover);
  }
</style>
